{
  "name": "iconsax-react",
  "version": "0.1.0",
  "description": "Iconsax for React is a fork of the original Iconsax project, which is a set of 1000+ icons designed for web and mobile applications. The fork includes additional features and improvements.",
  "contributors": [
    "Erfan Khadivar <rendinjast@gmail.com> (https://erfan.ee)",
    "Prograpp <contacto@prograpp.com.mx> (https://prograpp.com.mx)"
  ],
  "homepage": "https://iconsax-react.pages.dev/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/weprograpp/iconsax-react.git",
    "directory": "packages/iconsax-react"
  },
  "bugs": {
    "url": "https://github.com/weprograpp/iconsax-react/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/cjs/index.js"
      }
    },
    "./icons/*": {
      "import": {
        "types": "./dist/types/icons/*.d.mts",
        "default": "./dist/esm/*.js"
      },
      "require": {
        "types": "./dist/types/icons/*.d.cts",
        "default": "./dist/cjs/*.js"
      }
    },
    "./linear/*": {
      "import": {
        "types": "./dist/types/fixed/*.d.mts",
        "default": "./dist/esm/linear/*.js"
      },
      "require": {
        "types": "./dist/types/fixed/*.d.cts",
        "default": "./dist/cjs/linear/*.js"
      }
    },
    "./outline/*": {
      "import": {
        "types": "./dist/types/fixed/*.d.mts",
        "default": "./dist/esm/outline/*.js"
      },
      "require": {
        "types": "./dist/types/fixed/*.d.cts",
        "default": "./dist/cjs/outline/*.js"
      }
    },
    "./broken/*": {
      "import": {
        "types": "./dist/types/fixed/*.d.mts",
        "default": "./dist/esm/broken/*.js"
      },
      "require": {
        "types": "./dist/types/fixed/*.d.cts",
        "default": "./dist/cjs/broken/*.js"
      }
    },
    "./bold/*": {
      "import": {
        "types": "./dist/types/fixed/*.d.mts",
        "default": "./dist/esm/bold/*.js"
      },
      "require": {
        "types": "./dist/types/fixed/*.d.cts",
        "default": "./dist/cjs/bold/*.js"
      }
    },
    "./bulk/*": {
      "import": {
        "types": "./dist/types/fixed/*.d.mts",
        "default": "./dist/esm/bulk/*.js"
      },
      "require": {
        "types": "./dist/types/fixed/*.d.cts",
        "default": "./dist/cjs/bulk/*.js"
      }
    },
    "./twotone/*": {
      "import": {
        "types": "./dist/types/fixed/*.d.mts",
        "default": "./dist/esm/twotone/*.js"
      },
      "require": {
        "types": "./dist/types/fixed/*.d.cts",
        "default": "./dist/cjs/twotone/*.js"
      }
    },
    "./dist/*.d.ts": "./dist/*.d.ts",
    "./dist/*.js": "./dist/*.js",
    "./dist/*.json": "./dist/*.json",
    "./dist/*": "./dist/*.js",
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "icons/*": [
        "dist/types/icons/*"
      ],
      "linear/*": [
        "dist/types/fixed/*"
      ],
      "outline/*": [
        "dist/types/fixed/*"
      ],
      "broken/*": [
        "dist/types/fixed/*"
      ],
      "bold/*": [
        "dist/types/fixed/*"
      ],
      "bulk/*": [
        "dist/types/fixed/*"
      ],
      "twotone/*": [
        "dist/types/fixed/*"
      ]
    }
  },
  "sideEffects": false,
  "scripts": {
    "generate": "node ../../scripts/build.js react",
    "clean": "rm -rf dist",
    "build:bundle": "rollup --config rollup.config.js",
    "build:assets": "node ../../scripts/copyPackageAssets.js iconsax-react",
    "build": "yarn generate && yarn clean && yarn build:bundle && yarn build:assets",
    "test:fidelity": "node --max-old-space-size=4096 ../../tests/icon-fidelity.js",
    "test:generation": "node ../../tests/generation.js",
    "test:api": "node ../../tests/package-api.js",
    "test:exports": "node ../../tests/package-exports.js",
    "test:consumers": "node ../../tests/consumer-builds.js",
    "test:size": "node ../../tests/bundle-size.js",
    "test:package": "publint --pack false --level error && npm_config_cache=/tmp/iconsax-npm-cache attw --pack .",
    "test": "yarn build && yarn test:generation && yarn test:fidelity && yarn test:api && yarn test:exports && yarn test:consumers && yarn test:size && yarn test:package"
  },
  "keywords": [
    "icons",
    "react",
    "icon components",
    "iconsax"
  ],
  "files": [
    "dist",
    "MIGRATION.md"
  ],
  "devDependencies": {
    "@babel/core": "^7.15.5",
    "@babel/preset-env": "^7.15.6",
    "@babel/preset-react": "^7.14.5",
    "@rollup/plugin-babel": "^5.3.0",
    "@arethetypeswrong/cli": "^0.18.2",
    "@types/react": "^17.0.22",
    "esbuild": "^0.25.5",
    "iconsax-react-legacy": "npm:iconsax-react@0.0.8",
    "publint": "^0.3.12",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-test-renderer": "^17.0.2",
    "rollup": "^2.56.3",
    "rollup-plugin-multi-input": "^1.3.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.6",
    "webpack": "^5.107.0",
    "webpack-cli": "^6.0.1"
  },
  "peerDependencies": {
    "react": "*"
  }
}
